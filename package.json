{
  "name": "mamori-inspector",
  "displayName": "Mamori Inspector: Code Quality Guard",
  "description": "Unified code inspection platform for VS Code",
  "publisher": "meibinlab",
  "version": "0.3.5",
  "icon": "images/icon.png",
  "license": "Apache-2.0",
  "engines": {
    "vscode": "^1.109.0"
  },
  "categories": [
    "Linters"
  ],
  "keywords": [
    "lint",
    "sarif",
    "quality",
    "java",
    "eslint",
    "stylelint",
    "htmlhint"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/meibinlab/mamori-inspector.git"
  },
  "homepage": "https://github.com/meibinlab/mamori-inspector#readme",
  "bugs": {
    "url": "https://github.com/meibinlab/mamori-inspector/issues"
  },
  "activationEvents": [
    "onStartupFinished",
    "onLanguage:java",
    "onLanguage:javascript",
    "onLanguage:javascriptreact",
    "onLanguage:typescript",
    "onLanguage:typescriptreact",
    "onLanguage:css",
    "onLanguage:scss",
    "onLanguage:sass",
    "onLanguage:html"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "mamori-inspector.enableInWorkspace",
        "title": "Mamori Inspector: Enable In Workspace"
      },
      {
        "command": "mamori-inspector.disableInWorkspace",
        "title": "Mamori Inspector: Disable In Workspace"
      },
      {
        "command": "mamori-inspector.runWorkspaceCheck",
        "title": "Mamori Inspector: Run Workspace Check"
      },
      {
        "command": "mamori-inspector.setupTools",
        "title": "Mamori Inspector: Setup Managed Tools"
      },
      {
        "command": "mamori-inspector.clearToolCache",
        "title": "Mamori Inspector: Clear Managed Tool Cache"
      },
      {
        "command": "mamori-inspector.installGitHooks",
        "title": "Mamori Inspector: Install Git Hooks"
      },
      {
        "command": "mamori-inspector.uninstallGitHooks",
        "title": "Mamori Inspector: Uninstall Git Hooks"
      }
    ],
    "configuration": {
      "title": "Mamori Inspector",
      "properties": {
        "mamori-inspector.enabled": {
          "type": "boolean",
          "default": false,
          "scope": "resource",
          "markdownDescription": "Enable Mamori Inspector automatic save checks for the current workspace folder."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src .mamori",
    "package:vsix": "vsce package",
    "publish:vsce": "vsce publish",
    "test": "mocha --ui tdd \"out/test/**/*.test.js\"",
    "test:integration": "node ./scripts/run-vscode-test.mjs",
    "test:managed-tools": "npm run test -- --grep \"Sets up managed tools|Reports child process npm errors during managed tool setup|Reports the failing managed Node tool when npm installation fails during setup\""
  },
  "devDependencies": {
    "@vscode/vsce": "^3.6.1",
    "@types/vscode": "^1.109.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "typescript-eslint": "^8.54.0",
    "eslint": "^9.39.2",
    "typescript": "^5.9.3",
    "mocha": "^10.8.2",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}
