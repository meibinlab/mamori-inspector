{
  "name": "mamori-inspector",
  "displayName": "Mamori Inspector",
  "description": "Unified code inspection platform for VS Code",
  "version": "0.1.0",
  "engines": {
    "vscode": "^1.109.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onLanguage:java",
    "onLanguage:javascript",
    "onLanguage:javascriptreact",
    "onLanguage:css",
    "onLanguage:scss",
    "onLanguage:sass",
    "onLanguage:html"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "mamori-inspector.runWorkspaceCheck",
        "title": "Mamori Inspector: Run Workspace Check"
      },
      {
        "command": "mamori-inspector.installGitHooks",
        "title": "Mamori Inspector: Install Git Hooks"
      },
      {
        "command": "mamori-inspector.uninstallGitHooks",
        "title": "Mamori Inspector: Uninstall Git Hooks"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src .mamori",
    "test": "mocha --ui tdd \"out/test/**/*.test.js\"",
    "test:integration": "node ./scripts/run-vscode-test.mjs"
  },
  "devDependencies": {
    "@types/vscode": "^1.109.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "typescript-eslint": "^8.54.0",
    "eslint": "^9.39.2",
    "typescript": "^5.9.3",
    "mocha": "^10.8.2",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}
